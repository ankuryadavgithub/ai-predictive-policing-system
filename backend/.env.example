APP_NAME=AI Based Predictive Policing System
APP_VERSION=1.1.0
ENVIRONMENT=development

DATABASE_URL=postgresql://postgres:change-me@localhost:5432/crime_db
REDIS_URL=redis://localhost:6379/0
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=crime_db

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ACCESS_COOKIE_NAME=pps_access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_ADMIN_REGISTRATION=false
ADMIN_REGISTRATION_CODE=change-me

MAX_EVIDENCE_FILES=5
MAX_UPLOAD_SIZE_BYTES=10485760
REDIS_CACHE_TTL_SECONDS=120
RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT=10
REGISTRATION_RATE_LIMIT=5
REPORT_RATE_LIMIT=10
